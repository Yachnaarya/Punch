<style>
  body {
    font-family: Arial, sans-serif;
    background-color: #f9fafb;
    padding: 20px;
  }

  h1 {
    text-align: center;
    margin-bottom: 30px;
  }

  .action-buttons {
    text-align: center;
    margin-bottom: 30px;
  }

  .btn {
    padding: 10px 20px;
    border: none;
    font-weight: bold;
    border-radius: 5px;
    cursor: pointer;
    text-decoration: none;
    color: white;
  }

  .btn-primary {
    background-color: #007bff;
  }

  .btn-danger {
    background-color: #dc3545;
  }

  .btn:hover {
    opacity: 0.9;
  }

  #products {
    max-width: 600px;
    margin: 0 auto;
  }

  .punch-card {
    background-color: white;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 15px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
  }

  .punch-card strong {
    display: inline-block;
    width: 80px;
  }

  .label-in {
    color: #007bff; /* blue */
  }

  .label-out {
    color: #dc3545; /* red */
  }
</style>
<h1>Punches</h1>

<% today_punch = current_user.punchs.where("DATE(in_time) = ?", Date.current).last %>

<div class="action-buttons">
  <% if today_punch.nil? || today_punch.out_time.present? %>
    <%= button_to 'Punch In Now', punches_path(in_time: Time.current.in_time_zone('Asia/Kolkata')), method: :post, class: "btn btn-primary" %>
  <% else %>
    <%= button_to 'Punch Out Now', punch_path(today_punch, out_time: Time.current.in_time_zone('Asia/Kolkata')), method: :patch, class: "btn btn-danger" %>
  <% end %>
</div>

<div id="products">
  <% @punches.each do |punch| %>
    <div class="punch-card">
      <div>
        <strong class="label-in">In:</strong>
        <%= punch.in_time&.in_time_zone('Asia/Kolkata')&.strftime("%d %b %Y %I:%M %p") %>
      </div>
      <div>
        <strong class="label-out">Out:</strong>
        <%= punch.out_time.present? ? punch.out_time.in_time_zone('Asia/Kolkata').strftime("%d %b %Y %I:%M %p") : '---' %>
      </div>
    </div>
    
    <% end %>
    <div><strong>Total Break:</strong> <%= total_break_for(@punches) %></div>
    <div><strong>Number of entries:</strong> <%= total_entry_for(@punches) %></div>

</div>